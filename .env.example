# Preferred for personal Google accounts (without Shared Drives):
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Service account mode (use this only if you have Shared Drive setup):
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Recommended: folder id inside a Shared Drive where service account has Content manager rights.
GOOGLE_DRIVE_PARENT_FOLDER_ID=
GOOGLE_REPORTS_SHARE_MODE=anyone_with_link

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_AUTO_SET_WEBHOOK=true
APP_BASE_URL=

# Optional: API endpoint that returns process_model + financial_reports_model by telegram_id
REPORTS_SOURCE_API_URL=
REPORTS_SOURCE_API_KEY=
